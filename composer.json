{
    "config": {
        "platform-check": false
    },
    "require": {
        "firebase/php-jwt": "^7.0",
        "symfony/var-exporter": "^7.0",
        "zircote/swagger-php": "^4.0",
      "ext-pdo": "*"
    },
    "autoload": {
        "classmap": [
            "app/routes/"
        ],
        "psr-4": {
            "Core\\": "framework/",
            "DatabaseUtil\\": "app/database/",
            "Authorization\\": "app/authorization/"
        }
    },
    "scripts": {
        "docs": "./vendor/bin/openapi --bootstrap vendor/autoload.php app/routes/ -o docs/openapi.json"
    }
}